# PixieVeil Configuration

# DICOM Server Settings
dicom_server:
  ae_title: "PIXIEVEIL"
  port: 4070
  ip: "0.0.0.0"

# Storage Settings
storage:
  base_path: "./data/pixieveil"
  temp_path: "./data/tmp"
  max_storage_gb: 100

# Optional: remove or leave empty to keep archives local only
#remote_storage:
#  base_url: "https://your-storage-server"
#  auth_token: "your-bearer-token"

# HTTP Server Settings
http_server:
  port: 8070
  ip: "0.0.0.0"

# Study Management
study:
  completion_timeout: 120         # seconds of inactivity before a study is considered done
  completion_check_interval: 30   # how often (seconds) to check for completed studies
  max_study_size_mb: 4000

# Series Filtering
# Attribute-based rules use DICOM keyword names mapped to regular expressions.
# Include takes priority over exclude:
#   - If any include rule matches -> keep the series
#   - Else if any exclude rule matches -> filter the series out
#   - Else -> keep the series
# For multi-value attributes (e.g. ImageType) each value is tested individually.
series_filter:
  exclude_modalities: ["PR", "RT"]
  only_original_series: true
#  include:
#    SeriesDescription: "(?i)topogram"
#  exclude:
#    SeriesDescription: "(?i)dose\\s+report"
#    ImageType: "^DERIVED"

# Defacing
# Runs after anonymization on series identified as head scans.
# The external tool is called via `tool_command`, which receives the NIfTI
# input dir as {input_dir} and the output dir as {output_dir}.
defacing:
  enabled: false
  keep_backup: true          # keep anonymized-but-not-defaced series as <series>_pre_deface/; set false in production
  rotation_mode: "auto90"    # "none", "auto90", or "auto_all"
  tool_command: null         # e.g. "python run_CT-DEFACE.py -i {input_dir} -o {output_dir}"
  model_dir: ./data/nnUNet
  body_parts:                # BodyPartExamined values that indicate a head scan (case-insensitive)
    - HEAD
    - BRAIN
    - NECK
    - SKULL
  series_description_pattern: "(?i)(head|brain|skull|cranial|cerebr)"

# Logging
logging:
  level: "INFO"
  file: "./data/log/pixieveil.log"
  anontrail: "./data/log/anontrail.jsonl"

anonymization:
  profile: "research"
  profiles:
    research:
      # Research profile: pseudonymized data with preserved study dates
      PatientName: PSEUDO
      PatientID: PSEUDO
      PatientBirthDate: CLEAR
      PatientAge: KEEP
      PatientSex: KEEP
      InstitutionName: DEID_CENTER
      StudyID: RESEARCH
      StudyInstanceUID: PSEUDOUID
      StudyDescription: KEEP
      SeriesInstanceUID: PSEUDOUID
      SeriesDescription: KEEP
      FrameOfReferenceUID: PSEUDOUID
      ReferringPhysicianName: CLEAR
      OperatorsName: CLEAR
      PerformingPhysicianName: CLEAR
      AccessionNumber: CLEAR
      KeepPrivateTags: false
      PixelBlackout: false
      RetainStudyDate: true
    gdpr:
      # GDPR profile: fully anonymized with strong data protection
      PatientName: ANON
      PatientID: PSEUDO
      PatientBirthDate: CLEAR
      PatientAge: CLEAR
      PatientSex: CLEAR
      InstitutionName: CLEAR
      StudyID: STUDY
      StudyInstanceUID: NEWUID
      StudyDescription: CLEAR
      SeriesInstanceUID: NEWUID
      SeriesDescription: CLEAR
      FrameOfReferenceUID: NEWUID
      ReferringPhysicianName: CLEAR
      OperatorsName: CLEAR
      PerformingPhysicianName: CLEAR
      AccessionNumber: CLEAR
      KeepPrivateTags: false
      PixelBlackout: false
      RetainStudyDate: false
